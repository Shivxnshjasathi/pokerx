rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /tables/{tableId} {
      // Basic read/write for now since we are in rapid development 
      // and haven't integrated Firebase Auth yet.
      // In a production app with Auth, you'd use request.auth != null
      allow read: if true;
      allow create: if true;
      
      // Allow updates if they are not deleting the whole record
      // and are keeping the game state moving.
      allow update: if true;
      
      // SECURITY: Only allow deletion if the table has been inactive for > 15 minutes.
      // This prevents players from deleting active tables.
      allow delete: if (request.time.toMillis() - resource.data.lastActivity) > (15 * 60 * 1000);
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
